# Local development environment — copy to .env.local and fill in values.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoguessr_local"
ADMIN_PASSWORD=""

# Set to use real Cloudinary images locally; omit to use placeholder images.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Required only for AI tagging (scripts/tag-images.ts).
GEMINI_API_KEY=""